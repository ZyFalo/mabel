# =============================================================
# Mabel IA — Variables de Entorno
# Copia este archivo como .env y rellena con valores reales
# NUNCA commitear el archivo .env (está en .gitignore)
# =============================================================

# Base de datos PostgreSQL 16 (async driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mabel_ia

# Secreto para firmar tokens JWT (generar con: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# ─────────────────────────────────────────────────────────────
# LLM Provider — soporta cualquier endpoint OpenAI-compatible
# ─────────────────────────────────────────────────────────────
# Opción 1 (recomendada): Mabel-Gemma4 fine-tuneada propia en Modal.com.
#   El modelo está entrenado para responder breve, en español colombiano,
#   con system prompt fijo de 151 palabras (no editar — degrada calidad).
#   Cold start ~60-90s tras 5min idle. El backend retrae 8×10s automatic.
LLM_PROVIDER=openai_compat
# LLM_FLAVOR controla el shape del system prompt. Para Mabel-Gemma4
# DEBE ser 'mabel_gemma4' — sin esto se enviará el prompt verbose y se
# degradará la calidad del fine-tuning.
LLM_FLAVOR=mabel_gemma4
LLM_BASE_URL=https://williamandres1603--mabel-api-serve.modal.run/v1
LLM_API_KEY=not-used
LLM_MODEL=mabel-gemma4-e4b-Q4_K_M
LLM_TIMEOUT_MS=180000

# Opción 2 (fallback): Google Gemini via su endpoint OpenAI-compatible.
#   Más rápido (~3s) pero usa créditos free-tier limitados (1500 req/día).
#   Descomenta estas líneas y comenta las de arriba para activarlo.
# LLM_FLAVOR=generic
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=tu-gemini-api-key-aqui
# LLM_MODEL=gemini-1.5-flash
# LLM_TIMEOUT_MS=30000

# Legacy — solo se usa si LLM_API_KEY está vacío (fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173

# Voz ASR/TTS (Fase 7)
# WHISPER_MODEL=base
# PIPER_VOICE=es_ES-mls_9972-low
# PIPER_MODEL_PATH=models/piper/
# UPLOAD_DIR=uploads/audio/

# Admin seed (opcional, para entorno productivo)
# ADMIN_EMAIL=admin@umb.edu.co
# ADMIN_PASSWORD=Cambiar.SegunPolitica2026!
# ADMIN_DISPLAY_NAME=Administrador
